  /* -------- cabeçalho: sombra ao rolar + menu mobile -------- */
  function comportamentoCabecalho(){
    var cabecalho = document.getElementById('cabecalho');
    window.addEventListener('scroll', function(){
      if(!cabecalho) return;
      cabecalho.classList.toggle('com-sombra', window.scrollY > 6);
    });
    var botaoMenu = document.getElementById('botao-menu-mobile');
    var menu = document.getElementById('menu-principal');
    if(botaoMenu && menu){
      botaoMenu.addEventListener('click', function(){
        menu.classList.toggle('aberto');
        var aberto = menu.classList.contains('aberto');
        botaoMenu.setAttribute('aria-expanded', aberto ? 'true' : 'false');
      });
    }
  }

  /* -------- monta um card de produto a partir de uma entrada do feed -------- */
  function montarCardHTML(entrada){
    var titulo = entrada.title.$t;
    var link = '#';
    (entrada.link || []).forEach(function(l){ if(l.rel === 'alternate') link = l.href; });
    var imagem = entrada.media$thumbnail ? entrada.media$thumbnail.url.replace(/\/s72-c\//, '/s400-c/') : 'https://via.placeholder.com/400x400.png?text=Produto';
    return '' +
      '<article class="card-produto">' +
        '<a class="card-produto__imagem-caixa" href="' + link + '">' +
          '<img src="' + imagem + '" alt="' + titulo.replace(/"/g,'') + '" loading="lazy"/>' +
        '</a>' +
        '<div class="card-produto__corpo">' +
          '<a class="card-produto__titulo" href="' + link + '">' + titulo + '</a>' +
          '<a class="card-produto__botao" href="' + link + '">Ver produto</a>' +
        '</div>' +
      '</article>';
  }

  /* -------- busca postagens de um rótulo (label) via feed JSON do Blogger -------- */
  function carregarVitrinePorLabel(seletorContainer, label, excluirUrl, maxResultados){
    var container = document.querySelector(seletorContainer);
    if(!container) return;
    container.innerHTML = '<div class="skeleton" style="grid-column:1/-1;height:120px;border-radius:14px"></div>';
    var url = '/feeds/posts/summary/-/' + encodeURIComponent(label) + '?alt=json&max-results=' + (maxResultados || 8);
    fetch(url).then(function(r){ return r.json(); }).then(function(dados){
      var entradas = (dados.feed && dados.feed.entry) || [];
      if(excluirUrl){
        entradas = entradas.filter(function(e){
          var link = '#';
          (e.link || []).forEach(function(l){ if(l.rel === 'alternate') link = l.href; });
          return link !== excluirUrl;
        });
      }
      if(entradas.length === 0){
        container.innerHTML = '<p class="grade-vazia">Em breve, novos produtos nesta seção.</p>';
        return;
      }
      container.innerHTML = entradas.map(montarCardHTML).join('');
    }).catch(function(){
      container.innerHTML = '<p class="grade-vazia">Não foi possível carregar os produtos agora.</p>';
    });
  }

  function carregarVitrinesDaHome(){
    var c = window.CONFIG_LOJA || {};
    carregarVitrinePorLabel('[data-vitrine="destaques"]', c.labelDestaques);
    carregarVitrinePorLabel('[data-vitrine="lancamentos"]', c.labelLancamentos);
    carregarVitrinePorLabel('[data-vitrine="mais-vendidos"]', c.labelMaisVendidos);
    carregarVitrinePorLabel('[data-vitrine="promocoes"]', c.labelPromocoes);
  }

  function carregarRelacionados(){
    var container = document.querySelector('[data-vitrine-relacionados]');
    if(!container) return;
    var label = container.getAttribute('data-label');
    var excluir = container.getAttribute('data-excluir');
    carregarVitrinePorLabel('[data-vitrine-relacionados]', label, excluir, 4);
  }

  /* -------- acordeão de FAQ (delegação de evento) -------- */
  function comportamentoFAQ(){
    document.addEventListener('click', function(ev){
      var pergunta = ev.target.closest('.faq-pergunta');
      if(!pergunta) return;
      pergunta.closest('.faq-item').classList.toggle('aberto');
    });
  }

  /* -------- galeria: clique na miniatura troca a imagem principal -------- */
  function comportamentoGaleria(){
    document.addEventListener('click', function(ev){
      var miniatura = ev.target.closest('.galeria-miniaturas img');
      if(!miniatura) return;
      var galeria = miniatura.closest('.pagina-produto') || document;
      var principal = galeria.querySelector('.galeria-principal img');
      if(principal) principal.src = miniatura.src.replace(/\/s\d+-c\//, '/s800-c/') || miniatura.src;
      miniatura.parentElement.querySelectorAll('img').forEach(function(im){ im.classList.remove('ativa'); });
      miniatura.classList.add('ativa');
    });
  }

  /* -------- botão compartilhar -------- */
  function comportamentoCompartilhar(){
    var botao = document.getElementById('botao-compartilhar');
    if(!botao) return;
    botao.addEventListener('click', function(){
      var dados = { title: document.title, url: window.location.href };
      if(navigator.share){
        navigator.share(dados).catch(function(){});
      } else {
        navigator.clipboard.writeText(dados.url).then(function(){
          botao.textContent = 'Link copiado!';
          setTimeout(function(){ botao.innerHTML = 'Compartilhar'; }, 2000);
        });
      }
    });
  }

  /* -------- Schema.org Product: lê a caixa de preço do modelo-produto.html -------- */
  function injetarSchemaProduto(){
    var caixa = document.querySelector('[data-schema-produto]');
    if(!caixa) return;
    var dados = {
      '@context': 'https://schema.org/',
      '@type': 'Product',
      name: caixa.getAttribute('data-nome') || document.title,
      image: caixa.getAttribute('data-imagem') || '',
      description: caixa.getAttribute('data-descricao') || '',
      offers: {
        '@type': 'Offer',
        priceCurrency: 'BRL',
        price: caixa.getAttribute('data-preco') || '0',
        availability: (caixa.getAttribute('data-estoque') === '0') ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
        url: window.location.href
      }
    };
    var script = document.createElement('script');
    script.type = 'application/ld+json';
    script.text = JSON.stringify(dados);
    document.head.appendChild(script);
  }

  /* -------- inicialização -------- */
  document.addEventListener('DOMContentLoaded', function(){
    aplicarConfig();
    comportamentoCabecalho();
    comportamentoFAQ();
    comportamentoGaleria();
    comportamentoCompartilhar();
    carregarVitrinesDaHome();
    carregarRelacionados();
    injetarSchemaProduto();
  });
})();
