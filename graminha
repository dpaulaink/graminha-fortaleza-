<html b:version='2' class='v2' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
  <meta charset='UTF-8'/>
  <meta content='width=device-width, initial-scale=1' name='viewport'/>
  <meta content='IE=edge' http-equiv='X-UA-Compatible'/>

  <!-- SEO básico -->
  <title><b:if cond='data:blog.pageType == &quot;item&quot;'><data:blog.pageName/> | <data:blog.title/><b:else/><data:blog.pageTitle/></b:if></title>
  <b:if cond='data:blog.metaDescription'>
    <meta expr:content='data:blog.metaDescription' name='description'/>
  <b:else/>
    <meta content='Loja de ofertas e recomendações de produtos selecionados. Aproveite descontos, avaliações e frete facilitado.' name='description'/>
  </b:if>
  <link expr:href='data:blog.canonicalUrl' rel='canonical'/>

  <!-- Open Graph -->
  <meta expr:content='data:blog.pageName ? data:blog.pageName : data:blog.title' property='og:title'/>
  <meta expr:content='data:blog.canonicalUrl' property='og:url'/>
  <meta content='website' property='og:type'/>
  <meta expr:content='data:blog.title' property='og:site_name'/>

  <b:include data='blog' name='all-head-content'/>

  <!-- Tipografia: Poppins para títulos, Inter para texto. Remova este link se preferir só fontes do sistema. -->
  <link href='https://fonts.googleapis.com' rel='preconnect'/>
  <link href='https://fonts.gstatic.com' crossorigin='anonymous' rel='preconnect'/>
  <link href='https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap' rel='stylesheet'/>

  <b:skin><![CDATA[

/* ==================================================================
   CONFIGURAÇÕES DE CORES — altere só estas variáveis para trocar
   a identidade visual de toda a loja de uma vez.
   ================================================================== */
:root{
  --cor-primaria:#2E7D32;        /* verde principal */
  --cor-primaria-escura:#1B5E20; /* verde para hover/detalhes */
  --cor-primaria-clara:#E8F5E9;  /* verde bem claro, para fundos */
  --cor-dourada:#C9A227;         /* dourado para selos e detalhes premium */
  --cor-dourada-clara:#F4E9C9;
  --cor-fundo:#F6F7F6;           /* cinza claro de fundo */
  --cor-cartao:#FFFFFF;
  --cor-texto:#1B1F1C;
  --cor-texto-suave:#5B655D;
  --cor-borda:#E5E8E5;
  --cor-preco-antigo:#9AA39B;
  --cor-alerta:#D64545;

  --fonte-titulo:'Poppins', 'Segoe UI', sans-serif;
  --fonte-texto:'Inter', 'Segoe UI', sans-serif;

  --raio:14px;
  --raio-pequeno:8px;
  --sombra:0 4px 18px rgba(27,31,29,.07);
  --sombra-forte:0 10px 30px rgba(27,31,29,.14);
  --transicao:.25s ease;
}

/* ============ RESET E BASE ============ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:var(--fonte-texto);
  color:var(--cor-texto);
  background:var(--cor-fundo);
  line-height:1.55;
  -webkit-font-smoothing:antialiased;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
ul{list-style:none}
button{font-family:inherit;cursor:pointer;border:none;background:none}
input{font-family:inherit}
h1,h2,h3,h4{font-family:var(--fonte-titulo);line-height:1.25}
.wrap{max-width:1240px;margin:0 auto;padding:0 20px}
.somente-leitor-tela{position:absolute;left:-9999px}

/* ============ CABEÇALHO ============ */
.cabecalho{
  position:sticky;top:0;z-index:100;
  background:var(--cor-cartao);
  border-bottom:1px solid var(--cor-borda);
  transition:box-shadow var(--transicao);
}
.cabecalho.com-sombra{box-shadow:var(--sombra)}
.cabecalho__linha{
  display:flex;align-items:center;gap:24px;
  padding:14px 20px;max-width:1240px;margin:0 auto;
}
.cabecalho__marca{display:flex;align-items:center;gap:10px;flex-shrink:0}
.cabecalho__logo{width:42px;height:42px;border-radius:var(--raio-pequeno);object-fit:cover}
.cabecalho__nome{font-family:var(--fonte-titulo);font-weight:700;font-size:1.25rem;color:var(--cor-primaria-escura)}
.cabecalho__menu{display:flex;gap:22px;flex:1}
.cabecalho__menu a{
  font-weight:600;font-size:.94rem;color:var(--cor-texto);
  padding:8px 2px;position:relative;transition:color var(--transicao);
}
.cabecalho__menu a::after{
  content:'';position:absolute;left:0;bottom:0;width:0;height:2px;
  background:var(--cor-primaria);transition:width var(--transicao);
}
.cabecalho__menu a:hover{color:var(--cor-primaria)}
.cabecalho__menu a:hover::after{width:100%}
.cabecalho__busca{
  display:flex;align-items:center;flex:1;max-width:340px;
  background:var(--cor-fundo);border:1px solid var(--cor-borda);
  border-radius:999px;padding:6px 6px 6px 16px;
}
.cabecalho__busca input{flex:1;background:transparent;border:0;outline:0;font-size:.9rem}
.cabecalho__busca button{
  width:32px;height:32px;border-radius:50%;background:var(--cor-primaria);
  color:#fff;display:grid;place-items:center;flex-shrink:0;transition:background var(--transicao);
}
.cabecalho__busca button:hover{background:var(--cor-primaria-escura)}
.cabecalho__acoes{display:flex;align-items:center;gap:14px;flex-shrink:0}
.botao-whatsapp-topo{
  display:flex;align-items:center;gap:8px;background:#25D366;color:#fff;
  padding:9px 16px;border-radius:999px;font-weight:600;font-size:.86rem;
  transition:transform var(--transicao),box-shadow var(--transicao);
}
.botao-whatsapp-topo:hover{transform:translateY(-2px);box-shadow:var(--sombra)}
.cabecalho__menu-mobile-botao{display:none;background:none}
.cabecalho__menu-mobile-botao span,.cabecalho__menu-mobile-botao span::before,.cabecalho__menu-mobile-botao span::after{
  content:'';display:block;width:24px;height:2px;background:var(--cor-texto);position:relative;transition:var(--transicao)
}
.cabecalho__menu-mobile-botao span::before{position:absolute;top:-7px}
.cabecalho__menu-mobile-botao span::after{position:absolute;top:7px}

/* Botão flutuante de WhatsApp (mobile e desktop) */
.whatsapp-flutuante{
  position:fixed;right:20px;bottom:20px;z-index:200;
  width:58px;height:58px;border-radius:50%;background:#25D366;
  display:grid;place-items:center;box-shadow:var(--sombra-forte);
  animation:pulsar 2.4s infinite;
}
.whatsapp-flutuante svg{width:28px;height:28px;fill:#fff}
@keyframes pulsar{
  0%{box-shadow:0 0 0 0 rgba(37,211,102,.5)}
  70%{box-shadow:0 0 0 14px rgba(37,211,102,0)}
  100%{box-shadow:0 0 0 0 rgba(37,211,102,0)}
}

/* ============ BANNER PRINCIPAL (home) ============ */
.banner{
  position:relative;min-height:420px;display:flex;align-items:center;
  background-size:cover;background-position:center;border-radius:0 0 28px 28px;overflow:hidden;
}
.banner::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(100deg,rgba(15,30,17,.82) 0%,rgba(15,30,17,.45) 55%,rgba(15,30,17,.15) 100%);
}
.banner__conteudo{position:relative;z-index:1;max-width:640px;padding:0 20px;margin:0 auto;width:100%;max-width:1240px}
.banner__conteudo h1{color:#fff;font-size:clamp(1.9rem,4vw,3rem);font-weight:800;margin-bottom:14px;animation:surgir .6s ease both}
.banner__conteudo p{color:#EAF3EA;font-size:1.05rem;max-width:480px;margin-bottom:26px;animation:surgir .6s .1s ease both}
.banner__botoes{display:flex;gap:14px;flex-wrap:wrap;animation:surgir .6s .2s ease both}
@keyframes surgir{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.botao{
  display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:999px;
  font-weight:700;font-size:.94rem;transition:transform var(--transicao),box-shadow var(--transicao);
}
.botao-primario{background:var(--cor-dourada);color:#241D00}
.botao-primario:hover{transform:translateY(-3px);box-shadow:var(--sombra-forte)}
.botao-secundario{background:rgba(255,255,255,.14);color:#fff;border:1px solid rgba(255,255,255,.5);backdrop-filter:blur(2px)}
.botao-secundario:hover{background:rgba(255,255,255,.26)}

/* ============ CATEGORIAS (tiras de pílulas) ============ */
.categorias-tira{padding:26px 0 6px}
.categorias-tira__lista{display:flex;gap:12px;overflow-x:auto;padding-bottom:8px}
.categoria-pilula{
  flex-shrink:0;background:var(--cor-cartao);border:1px solid var(--cor-borda);
  padding:10px 20px;border-radius:999px;font-weight:600;font-size:.86rem;
  transition:var(--transicao);
}
.categoria-pilula:hover{background:var(--cor-primaria);color:#fff;border-color:var(--cor-primaria)}

/* ============ SEÇÕES GERAIS ============ */
.secao{padding:38px 0}
.secao__cabecalho{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px}
.secao__titulo{font-size:1.5rem;font-weight:700;position:relative;padding-left:16px}
.secao__titulo::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:5px;border-radius:4px;background:var(--cor-dourada)}
.secao__ver-tudo{font-weight:600;font-size:.88rem;color:var(--cor-primaria)}
.secao__ver-tudo:hover{text-decoration:underline}

/* ============ GRADE E CARDS DE PRODUTO ============ */
.grade-produtos{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:18px}
.card-produto{
  background:var(--cor-cartao);border-radius:var(--raio);overflow:hidden;
  border:1px solid var(--cor-borda);transition:transform var(--transicao),box-shadow var(--transicao);
  display:flex;flex-direction:column;position:relative;
}
.card-produto:hover{transform:translateY(-5px);box-shadow:var(--sombra-forte)}
.card-produto__imagem-caixa{position:relative;aspect-ratio:1/1;overflow:hidden;background:var(--cor-fundo)}
.card-produto__imagem-caixa img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.card-produto:hover .card-produto__imagem-caixa img{transform:scale(1.07)}
.selo{
  position:absolute;top:10px;left:10px;padding:5px 11px;border-radius:999px;
  font-size:.68rem;font-weight:700;letter-spacing:.03em;text-transform:uppercase;color:#fff;z-index:2;
}
.selo-oferta{background:var(--cor-alerta)}
.selo-novo{background:var(--cor-primaria)}
.selo-mais-vendido{background:var(--cor-dourada);color:#241D00}
.selo-economia{
  position:absolute;top:10px;right:10px;background:var(--cor-texto);color:#fff;
  border-radius:50%;width:46px;height:46px;display:grid;place-items:center;
  font-size:.68rem;font-weight:800;line-height:1.05;text-align:center;z-index:2;
}
.card-produto__corpo{padding:14px;display:flex;flex-direction:column;gap:6px;flex:1}
.card-produto__titulo{font-size:.9rem;font-weight:600;min-height:2.6em;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.card-produto__precos{margin-top:auto}
.card-produto__preco-antigo{font-size:.78rem;color:var(--cor-preco-antigo);text-decoration:line-through}
.card-produto__preco{font-size:1.18rem;font-weight:800;color:var(--cor-primaria-escura)}
.card-produto__parcelas{font-size:.72rem;color:var(--cor-texto-suave)}
.card-produto__botao{
  margin-top:10px;background:var(--cor-primaria);color:#fff;text-align:center;
  padding:10px;border-radius:var(--raio-pequeno);font-weight:700;font-size:.85rem;
  transition:background var(--transicao);
}
.card-produto__botao:hover{background:var(--cor-primaria-escura)}
.grade-vazia{color:var(--cor-texto-suave);font-size:.9rem;padding:20px 0}

/* skeleton de carregamento (lazy) */
.skeleton{background:linear-gradient(90deg,#eee 25%,#f6f6f6 37%,#eee 63%);background-size:400% 100%;animation:brilho 1.4s infinite}
@keyframes brilho{0%{background-position:100% 0}100%{background-position:0 0}}

/* ============ AVALIAÇÕES ============ */
.avaliacoes{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px}
.avaliacao-card{background:var(--cor-cartao);border:1px solid var(--cor-borda);border-radius:var(--raio);padding:18px}
.avaliacao-card__estrelas{color:var(--cor-dourada);margin-bottom:8px;font-size:.9rem}
.avaliacao-card__texto{font-size:.88rem;color:var(--cor-texto-suave);margin-bottom:10px}
.avaliacao-card__autor{font-weight:700;font-size:.84rem}

/* ============ BREADCRUMB ============ */
.trilha{font-size:.82rem;color:var(--cor-texto-suave);padding:16px 0}
.trilha a:hover{color:var(--cor-primaria)}
.trilha span{margin:0 6px}

/* ============ PÁGINA DE PRODUTO (postagem) ============ */
.pagina-produto{background:var(--cor-cartao);border-radius:var(--raio);padding:28px;box-shadow:var(--sombra);margin-bottom:30px}
.pagina-produto__topo{display:grid;grid-template-columns:1fr 1fr;gap:36px}
@media(max-width:860px){.pagina-produto__topo{grid-template-columns:1fr}}

/* Galeria */
.galeria-principal{border-radius:var(--raio);overflow:hidden;border:1px solid var(--cor-borda);aspect-ratio:1/1;margin-bottom:12px}
.galeria-principal img{width:100%;height:100%;object-fit:cover}
.galeria-miniaturas{display:flex;gap:10px;overflow-x:auto}
.galeria-miniaturas img{
  width:70px;height:70px;object-fit:cover;border-radius:var(--raio-pequeno);
  border:2px solid transparent;cursor:pointer;opacity:.7;transition:var(--transicao);flex-shrink:0;
}
.galeria-miniaturas img:hover{opacity:1}
.galeria-miniaturas img.ativa{border-color:var(--cor-primaria);opacity:1}
.produto-video{margin-top:16px;border-radius:var(--raio);overflow:hidden;aspect-ratio:16/9}
.produto-video iframe,.produto-video video{width:100%;height:100%;border:0}

/* Informações e preço */
.produto-titulo{font-size:1.6rem;font-weight:700;margin-bottom:10px}
.produto-meta{display:flex;gap:14px;flex-wrap:wrap;font-size:.82rem;color:var(--cor-texto-suave);margin-bottom:16px}
.caixa-preco{background:var(--cor-primaria-clara);border-radius:var(--raio);padding:18px;margin-bottom:18px}
.caixa-preco__antigo{font-size:.9rem;color:var(--cor-preco-antigo);text-decoration:line-through}
.caixa-preco__linha{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.caixa-preco__atual{font-size:2rem;font-weight:800;color:var(--cor-primaria-escura)}
.caixa-preco__economia{background:var(--cor-dourada);color:#241D00;font-weight:800;font-size:.78rem;padding:5px 10px;border-radius:6px}
.caixa-preco__parcelas{font-size:.86rem;color:var(--cor-texto-suave);margin-top:6px}
.caixa-preco__estoque{margin-top:14px}
.barra-estoque{height:8px;border-radius:4px;background:#DDE3DD;overflow:hidden;margin-top:6px}
.barra-estoque__preenchimento{height:100%;background:var(--cor-alerta);border-radius:4px}
.caixa-preco__estoque small{color:var(--cor-texto-suave)}

.produto-botoes{display:flex;flex-direction:column;gap:10px;margin-bottom:18px}
.botao-grande{padding:16px;border-radius:var(--raio-pequeno);font-weight:800;font-size:1rem;text-align:center;display:flex;align-items:center;justify-content:center;gap:10px}
.botao-comprar{background:var(--cor-primaria);color:#fff;transition:background var(--transicao),transform var(--transicao)}
.botao-comprar:hover{background:var(--cor-primaria-escura);transform:translateY(-2px)}
.linha-botoes-secundarios{display:flex;gap:10px}
.botao-linha{flex:1;padding:12px;border-radius:var(--raio-pequeno);border:1px solid var(--cor-borda);font-weight:600;font-size:.85rem;text-align:center;display:flex;align-items:center;justify-content:center;gap:6px;transition:var(--transicao)}
.botao-linha:hover{border-color:var(--cor-primaria);color:var(--cor-primaria)}
.botao-linha--whatsapp{border-color:#25D366;color:#128C4A}
.botao-linha--whatsapp:hover{background:#25D366;color:#fff}

/* Corpo: descrição, benefícios, specs, FAQ (renderizados a partir do modelo-produto.html) */
.produto-secao{margin-top:34px}
.produto-secao h2{font-size:1.25rem;margin-bottom:14px;padding-left:14px;border-left:4px solid var(--cor-dourada)}
.produto-descricao{color:var(--cor-texto);font-size:.96rem}
.lista-beneficios li{display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;font-size:.92rem}
.lista-beneficios li::before{content:'✓';flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--cor-primaria);color:#fff;display:grid;place-items:center;font-size:.72rem;font-weight:800}
.tabela-especificacoes{width:100%;border-collapse:collapse;font-size:.9rem}
.tabela-especificacoes tr:nth-child(odd){background:var(--cor-fundo)}
.tabela-especificacoes td{padding:11px 14px;border-bottom:1px solid var(--cor-borda)}
.tabela-especificacoes td:first-child{font-weight:600;width:40%;color:var(--cor-texto-suave)}

.faq-item{border-bottom:1px solid var(--cor-borda)}
.faq-pergunta{width:100%;text-align:left;padding:16px 4px;display:flex;justify-content:space-between;align-items:center;font-weight:600;font-size:.94rem}
.faq-pergunta::after{content:'+';font-size:1.3rem;color:var(--cor-primaria);transition:transform var(--transicao)}
.faq-item.aberto .faq-pergunta::after{transform:rotate(45deg)}
.faq-resposta{max-height:0;overflow:hidden;transition:max-height .3s ease;font-size:.9rem;color:var(--cor-texto-suave)}
.faq-item.aberto .faq-resposta{max-height:400px;padding-bottom:16px}

.relacionados{margin-top:10px}

/* Comentários */
#comentarios-produto{background:var(--cor-cartao);border-radius:var(--raio);padding:24px;box-shadow:var(--sombra)}

/* ============ RODAPÉ ============ */
.rodape{background:#12251A;color:#D8E4DA;margin-top:50px;padding:50px 0 20px}
.rodape__grade{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:30px;margin-bottom:36px}
@media(max-width:760px){.rodape__grade{grid-template-columns:1fr 1fr}}
.rodape__marca{font-family:var(--fonte-titulo);font-weight:700;font-size:1.2rem;color:#fff;margin-bottom:10px}
.rodape__texto{font-size:.86rem;color:#A9BBAC}
.rodape h4{font-size:.9rem;color:#fff;margin-bottom:14px;text-transform:uppercase;letter-spacing:.04em}
.rodape ul li{margin-bottom:9px;font-size:.86rem}
.rodape ul li a:hover{color:var(--cor-dourada)}
.rodape__redes{display:flex;gap:10px;margin-top:14px}
.rodape__redes a{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.08);display:grid;place-items:center;transition:var(--transicao)}
.rodape__redes a:hover{background:var(--cor-dourada);color:#12251A}
.rodape__redes svg{width:17px;height:17px;fill:currentColor}
.rodape__base{border-top:1px solid rgba(255,255,255,.1);padding-top:18px;font-size:.78rem;color:#8DA091;text-align:center}

/* ============ PAGINAÇÃO ============ */
.paginacao{display:flex;justify-content:center;gap:10px;margin:30px 0}
.paginacao a{padding:10px 18px;border-radius:999px;background:var(--cor-cartao);border:1px solid var(--cor-borda);font-weight:600;font-size:.86rem;transition:var(--transicao)}
.paginacao a:hover{background:var(--cor-primaria);color:#fff;border-color:var(--cor-primaria)}

/* ============ RESPONSIVO ============ */
@media(max-width:900px){
