<!-- ==================================================================
     ÚLTIMAS POSTAGENS / PÁGINA DE PRODUTO
     Widget nativo do Blog — garante que o Google indexe os links de
     todas as postagens (bom para SEO) e renderiza a página de produto
     completa quando o visitante abre uma postagem.
     ================================================================== -->
<b:section id='main' class='main-secao' showaddelement='no'>
  <b:widget id='Blog1' locked='true' title='Blog' type='Blog'>
    <b:includable id='main' var='top'>
      <div class="wrap">
        <b:if cond='data:blog.pageType == &quot;index&quot; and data:blog.url == data:blog.homepageUrl'>
          <section class="secao">
            <div class="secao__cabecalho">
              <h2 class="secao__titulo">Últimas Postagens</h2>
            </div>
            <div class="grade-produtos">
              <b:loop values='data:posts' var='post'>
                <b:include data='post' name='cartaoUltimaPostagem'/>
              </b:loop>
            </div>
          </section>
        </b:if>

        <b:if cond='data:blog.pageType == &quot;item&quot;'>
          <b:loop values='data:posts' var='post'>
            <b:include data='post' name='paginaProduto'/>
          </b:loop>
        </b:if>

        <b:if cond='data:blog.pageType in {&quot;archive&quot;,&quot;search&quot;} and data:blog.url != data:blog.homepageUrl'>
          <nav class="trilha">
            <a expr:href='data:blog.homepageUrl'>Home</a><span>/</span><data:blog.pageName/>
          </nav>
          <section class="secao">
            <div class="grade-produtos">
              <b:loop values='data:posts' var='post'>
                <b:include data='post' name='cartaoUltimaPostagem'/>
              </b:loop>
              <b:if cond='data:posts.size == 0'>
                <p class="grade-vazia">Nenhum produto encontrado nesta categoria.</p>
              </b:if>
            </div>
          </section>
        </b:if>

        <b:include data='top' name='paginacao'/>
      </div>
    </b:includable>

    <!-- Card usado nas listagens (últimas postagens, categorias, busca) -->
    <b:includable id='cartaoUltimaPostagem' var='post'>
      <article class="card-produto">
        <a class="card-produto__imagem-caixa" expr:href='data:post.url'>
          <b:if cond='data:post.featuredImage'>
            <img expr:alt='data:post.title' loading="lazy" expr:src='resizeImage(data:post.featuredImage, 400, "1:1")'/>
          <b:else/>
            <img alt="Produto" loading="lazy" src="https://via.placeholder.com/400x400.png?text=Produto"/>
          </b:if>
        </a>
        <div class="card-produto__corpo">
          <a class="card-produto__titulo" expr:href='data:post.url'><data:post.title/></a>
          <a class="card-produto__botao" expr:href='data:post.url'>Ver produto</a>
        </div>
      </article>
    </b:includable>

    <!-- Paginação nativa do Blogger -->
    <b:includable id='paginacao' var='top'>
      <b:if cond='data:top.olderPageUrl or data:top.newerPageUrl'>
        <nav class="paginacao">
          <b:if cond='data:top.newerPageUrl'><a expr:href='data:top.newerPageUrl'>&#8592; Mais recentes</a></b:if>
          <b:if cond='data:top.olderPageUrl'><a expr:href='data:top.olderPageUrl'>Mais antigas &#8594;</a></b:if>
        </nav>
      </b:if>
    </b:includable>

    <!-- ============================================================
         PÁGINA DE PRODUTO COMPLETA
         O corpo da postagem (data:post.body) deve ser criado a partir
         do arquivo modelo-produto.html: é ele que traz a galeria,
         preço, benefícios, especificações e FAQ.
         ============================================================ -->
    <b:includable id='paginaProduto' var='post'>
      <nav class="trilha" itemscope="itemscope" itemtype="https://schema.org/BreadcrumbList">
        <a expr:href='data:blog.homepageUrl'>Home</a><span>/</span>
        <b:if cond='data:post.labels'>
          <a expr:href='data:post.labels.first.url'><data:post.labels.first.name/></a><span>/</span>
        </b:if>
        <data:post.title/>
      </nav>

      <article class="pagina-produto" data-post-title.data-post-url="">
        <h1 class="produto-titulo"><data:post.title/></h1>
        <div class="produto-meta">
          <span>Publicado em <data:post.date/></span>
          <b:if cond='data:post.labels'>
            <span>Categoria:
              <b:loop values='data:post.labels' var='label'>
                <a expr:href='data:label.url'><data:label.name/></a><b:if cond='not data:label.isLast'>, </b:if>
              </b:loop>
            </span>
          </b:if>
        </div>

        <!-- O conteúdo abaixo vem inteiramente do corpo da postagem
             (colado a partir do modelo-produto.html) -->
        <div class="produto-corpo" id="corpo-produto-<data:post.id/>">
          <data:post.body/>
        </div>

        <div class="linha-botoes-secundarios" style="margin-top:22px">
          <button class="botao-linha" id="botao-compartilhar" type="button">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="10.6" x2="15.4" y2="6.4"/><line x1="8.6" y1="13.4" x2="15.4" y2="17.6"/></svg>
            Compartilhar
          </button>
          <a class="botao-linha botao-linha--whatsapp" href="#" id="whatsapp-produto" rel="nofollow" target="_blank">Dúvidas? Fale no WhatsApp</a>
        </div>
      </article>

      <!-- Produtos relacionados: primeira categoria da postagem atual -->
      <b:if cond='data:post.labels'>
        <section class="secao relacionados">
          <div class="secao__cabecalho">
            <h2 class="secao__titulo">Produtos Relacionados</h2>
          </div>
          <div class="grade-produtos" data-vitrine-relacionados expr:data-label='data:post.labels.first.name' expr:data-excluir='data:post.url'></div>
        </section>
      </b:if>

      <section class="secao" id="comentarios-produto">
        <div class="secao__cabecalho">
          <h2 class="secao__titulo">Comentários</h2>
        </div>
        <b:include data='post' name='comentarios'/>
      </section>

      <!-- Schema.org Product — preenchido via JS lendo os atributos
           data-* da caixa de preço presente no modelo-produto.html -->
      <script expr:data-post-url='data:post.url' expr:data-post-title='data:post.title' expr:data-post-image='data:post.featuredImage' id="dados-produto-atual" type="application/json"></script>
    </b:includable>

  </b:widget>
</b:section>

