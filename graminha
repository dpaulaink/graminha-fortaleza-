      <div class="grade-produtos" data-vitrine="destaques"></div>
    </section>

    <section class="secao">
      <div class="secao__cabecalho">
        <h2 class="secao__titulo">Lançamentos</h2>
      </div>
      <div class="grade-produtos" data-vitrine="lancamentos"></div>
    </section>

    <section class="secao">
      <div class="secao__cabecalho">
        <h2 class="secao__titulo">Mais Vendidos</h2>
      </div>
      <div class="grade-produtos" data-vitrine="mais-vendidos"></div>
    </section>

    <section class="secao">
      <div class="secao__cabecalho">
        <h2 class="secao__titulo">Promoções</h2>
      </div>
